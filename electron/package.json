{
    "name": "sentopic-desktop",
    "version": "1.0.0",
    "description": "Sentopic Reddit Analytics - Desktop Application",
    "main": "main.js",
    "author": "Sentopic",
    "license": "MIT",
    "private": true,
    "scripts": {
      "start": "electron .",
      "dev": "electron . --dev",
      "pack": "electron-builder --dir",
      "dist": "electron-builder",
      "postinstall": "electron-builder install-app-deps"
    },
    "devDependencies": {
      "electron": "^28.0.0",
      "electron-builder": "^24.9.1",
      "concurrently": "^8.2.0",
      "wait-on": "^7.2.0"
    },
    "dependencies": {
      "axios": "^1.6.0"
    },
    "build": {
      "appId": "com.sentopic.desktop",
      "productName": "Sentopic",
      "directories": {
        "output": "dist"
      },
      "files": [
        "main.js",
        "preload.js",
        "renderer.js",
        "../frontend/dist/**/*"
      ],
      "mac": {
        "category": "public.app-category.productivity",
        "target": "dmg"
      },
      "win": {
        "target": "nsis"
      },
      "linux": {
        "target": "AppImage",
        "category": "Office"
      }
    }
  }